# ============================================================
# CONFIGURACIÓN DEL SERVIDOR - Pollería Online
# Copia este archivo como .env y completa los valores
# ============================================================

# Puerto del servidor
PORT=4000

# ============================================================
# BASE DE DATOS PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=polleria_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ============================================================
# SEGURIDAD
# ============================================================
# Cambia este valor por una cadena larga y aleatoria
JWT_SECRET=polleria_super_secret_key_cambia_esto_en_produccion_2024

# ============================================================
# WHATSAPP
# Formato: código de país + número sin espacios ni +
# Ejemplo México: 521XXXXXXXXXX (52 = México, 1 = prefijo móvil)
# ============================================================
OWNER_WHATSAPP=521XXXXXXXXXX
OWNER_NAME=La Pollería

# ============================================================
# FRONTEND (para CORS)
# ============================================================
CLIENT_URL=http://localhost:5173
